# Copy to .env and adjust as needed.

# Public port the site is served on (http://localhost:<port>)
WORDPRESS_PORT=8080

# Database credentials (used by the db, wordpress and wpcli services)
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=rootpass

# WordPress administrator account created during provisioning
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=admin
WORDPRESS_ADMIN_EMAIL=admin@example.com

# Set to 1 to enable WP_DEBUG
WORDPRESS_DEBUG=0
