{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "780px",
      "wideSize": "1140px"
    },
    "color": {
      "custom": true,
      "customGradient": true,
      "palette": [
        { "slug": "primary", "color": "#6f4e37", "name": "Primary" },
        { "slug": "accent", "color": "#e0a458", "name": "Accent" },
        { "slug": "text", "color": "#2b2b2b", "name": "Text" },
        { "slug": "background", "color": "#fffaf3", "name": "Background" }
      ]
    },
    "typography": {
      "customFontSize": true,
      "fontSizes": [
        { "slug": "small", "size": "0.9rem", "name": "Small" },
        { "slug": "medium", "size": "1.1rem", "name": "Medium" },
        { "slug": "large", "size": "1.5rem", "name": "Large" },
        { "slug": "x-large", "size": "2.2rem", "name": "Extra large" }
      ]
    },
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "styles": {
    "color": {
      "background": "#fffaf3",
      "text": "#2b2b2b"
    },
    "elements": {
      "link": {
        "color": { "text": "#6f4e37" }
      }
    }
  }
}
