# Local environment overrides
.env

# OS / editor noise
.DS_Store
Thumbs.db
*.swp

# Docker volume dumps / local artifacts
/wp-data/
/db-data/

# Netlify CLI local state
.netlify/

# NOTE: ./dist (the generated static export) is intentionally committed so that
# Netlify's Git-based deploys have something to publish — WordPress can't build
# in Netlify's CI. Regenerate it with ./scripts/export.sh and commit the result.

# Premium/licensed theme & plugin binaries and demo exports (keep the READMEs)
site-config/themes/*
site-config/plugins/*
site-config/import/*
!site-config/themes/README.md
!site-config/plugins/README.md
!site-config/import/README.md
